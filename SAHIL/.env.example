ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://assetflow:assetflow@localhost:5432/assetflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

JWT_SECRET_KEY=replace-with-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

BCRYPT_ROUNDS=12
